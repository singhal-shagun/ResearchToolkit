    "version": "0.2.0",
    "configurations": [
        {
            "name": "Python Debugger: Current File with Arguments - Django RunServer",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}\\BackendCode\\manage.py",
            "console": "internalConsole",
            "args": [
                "runserver"
            ],
            "django": true,
            "justMyCode": true
        },
        {
            "name": "Python Debugger: Current File - NiceGUI",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}\\main.py",
            "console": "internalConsole"
        }
    ]
}